{
  "name": "esourcing-coe-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "test": "npm run test:run",
    "test:run": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "deploy:check": "tsx scripts/checkDeployConfig.ts",
    "supabase:types": "supabase gen types typescript --linked --schema public > src/domain/database.types.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^8.1.0"
  }
}
