# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit it.
# In Vercel, configure these same variables under Project Settings → Environment Variables.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Production default is admin-created / invited Supabase users.
# Set to true only for deliberate open-signup environments.
VITE_AUTH_SIGNUP_ENABLED=false

# Optional: one-click account switch for local dev or controlled test deploys.
# Requires seeded Supabase accounts with profiles.role = admin/user.
VITE_ENABLE_ACCOUNT_SWITCH=false
VITE_DEV_ADMIN_EMAIL=admin@example.com
VITE_DEV_ADMIN_PASSWORD=admin-password
VITE_DEV_USER_EMAIL=user@example.com
VITE_DEV_USER_PASSWORD=user-password
